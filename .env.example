# Twitter/X developer app credentials (developer.twitter.com -> your app -> Keys and tokens)
# App permissions must be set to "Read and Write" before generating the access token/secret.
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Bluesky login (bsky.app -> Settings -> App passwords -> create one, don't use your real password)
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=

# Optional: override per-platform single-post character limits (defaults: 280 / 300).
# Only raise TWITTER_MAX_LEN if your account + API access actually supports longer posts.
# TWITTER_MAX_LEN=280
# BLUESKY_MAX_LEN=300
